<% layout("./boilerplate/boilerplate") %>

<h3 class="text-white p-3">Explore</h3>

<form method="GET" action="/explore" class="m-3">
  <input type="text" name="q" placeholder="Search..." class="form-control w-25 d-inline" />
  <select name="type" class="form-select w-25 d-inline ms-2">
    <option value="article">Articles</option>
    <option value="github">GitHub</option>
  </select>
  <button class="btn btn-primary ms-2">Explore</button>
</form>

<% posts.forEach(p => { %>
  <div class="card bg-dark text-white m-3 p-3">

    <% if (p.type === "article") { %>
      <h5>
        <a href="<%= p.url %>" target="_blank" class="text-info text-decoration-none">
          <%= p.title %>
        </a>
      </h5>
      <p class="text-muted"><%= p.description %></p>

    <% } else if (p.type === "github") { %>
  <h5>
    <a href="<%= p.url %>" target="_blank" class="text-info text-decoration-none">
      <%= p.repoName %>
    </a>
  </h5>

  <p class="text-muted"><%= p.description || "No description available" %></p>

  <div class="text-muted">
    <%= p.stars %> stars
  </div>
    <% } else { %>
      <!-- Normal DB post -->
      <p><%= p.content %></p>
    <% } %>

    <small>Match Score: <%= p.matchScore %>%</small>
    <% if (p.matchScore > 80) { %>
      <span class="badge bg-success ms-2">Highly Relevant</span>
    <% } %>

  </div>
<% }) %>
